---
// =============================================================================
// Leonida Hub — Collectible Tracker
// src/pages/tracker.astro
//
// Client-side single-page tracking view. The collectibles catalogue is
// imported at build time (zero-latency static JSON, no fetch needed) and
// passed into the page as an inline script payload. All filtering, progress
// computation, and checkbox-toggle interaction happens client-side via a
// vanilla TypeScript island that talks directly to src/utils/storage.ts —
// no framework runtime, matching this project's islands architecture.
// =============================================================================

import Layout from "../layouts/Layout.astro";
import collectiblesData from "../data/collectibles.json";

const { categories, items } = collectiblesData;
const categoryEntries = Object.entries(categories) as [string, string][];
---

<Layout
  title="Collectible Tracker"
  description="Track every GTA VI collectible — Hidden Packages, Stunt Jumps, Enterable Buildings, and more. Filter by category, check off finds, progress saves automatically in your browser."
>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6" aria-labelledby="tracker-heading">

    <!-- Page header -->
    <div class="mb-8">
      <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-neon-border bg-neon-glow px-3 py-1">
        <span class="h-1.5 w-1.5 shrink-0 animate-pulse-neon rounded-full bg-neon" aria-hidden="true"></span>
        <span class="font-mono text-[11px] tracking-[0.12em] text-neon">SAVES AUTOMATICALLY · NO ACCOUNT NEEDED</span>
      </div>
      <h1 id="tracker-heading" class="font-display text-4xl font-extrabold uppercase tracking-tight text-gray-100 sm:text-5xl">
        Collectible Tracker
      </h1>
      <p class="mt-2 max-w-2xl text-sm text-gray-400 sm:text-base">
        Filter by category, mark items as you find them, and watch your completion
        percentage update live. Your progress is stored only in this browser.
      </p>
    </div>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- TWO-PANEL LAYOUT                                                  -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[280px_1fr] lg:items-start lg:gap-8">

      <!-- ══════════════════════════════════════════════════════════════ -->
      <!-- LEFT PANEL — filters + progress card                            -->
      <!-- ══════════════════════════════════════════════════════════════ -->
      <aside
        class="flex flex-col gap-4 lg:sticky lg:top-20"
        aria-label="Filters and progress"
      >

        <!-- Progress card — values populated client-side at runtime -->
        <div
          id="progress-card"
          class="rounded-xl border border-neon-border bg-gradient-to-b from-neon-glow to-transparent p-5"
          aria-live="polite"
          aria-label="Completion progress"
        >
          <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-neon">Your progress</p>

          <div class="mt-2 flex items-baseline gap-2">
            <span id="progress-percent" class="font-display text-4xl font-extrabold tabular-nums text-gray-100">0.0%</span>
          </div>

          <div
            class="mt-3 h-2 w-full overflow-hidden rounded-full bg-white/10"
            role="progressbar"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            id="progress-bar-track"
          >
            <div id="progress-bar-fill" class="h-full rounded-full bg-neon transition-all duration-300 ease-out" style="width: 0%"></div>
          </div>

          <p class="mt-2 font-mono text-xs text-gray-500">
            <span id="progress-completed">0</span> / <span id="progress-total">{items.length}</span> found
          </p>

          <button
            type="button"
            id="reset-progress-btn"
            class="mt-4 w-full rounded-md border border-white/10 px-3 py-2 text-xs font-medium text-gray-400 transition-colors hover:border-red-500/30 hover:bg-red-500/10 hover:text-red-400"
          >
            Reset all progress
          </button>
        </div>

        <!-- Category filter checkboxes -->
        <div class="rounded-xl border border-white/10 bg-slate p-5">
          <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.14em] text-gray-500">Filter by category</p>

          <fieldset class="flex flex-col gap-2.5">
            <legend class="sr-only">Collectible category filters</legend>

            {
              categoryEntries.map(([categoryKey, categoryLabel]) => (
                <label
                  class="flex cursor-pointer items-center justify-between gap-3 rounded-md px-2 py-1.5 transition-colors hover:bg-white/[0.04]"
                  for={`filter-${categoryKey}`}
                >
                  <span class="flex items-center gap-2.5">
                    <input
                      type="checkbox"
                      id={`filter-${categoryKey}`}
                      class="category-filter-checkbox h-4 w-4 shrink-0 cursor-pointer rounded border-white/20 bg-midnight text-neon accent-neon focus-visible:ring-2 focus-visible:ring-neon/40"
                      data-category={categoryKey}
                      checked
                    />
                    <span class="text-sm text-gray-300">{categoryLabel}</span>
                  </span>
                  <span
                    class="category-count rounded bg-white/[0.06] px-1.5 py-0.5 font-mono text-[10px] text-gray-500"
                    data-category-count={categoryKey}
                  >
                    0
                  </span>
                </label>
              ))
            }
          </fieldset>

          <div class="mt-4 flex gap-2 border-t border-white/[0.06] pt-3">
            <button
              type="button"
              id="select-all-categories-btn"
              class="flex-1 rounded-md border border-white/10 px-2 py-1.5 text-xs font-medium text-gray-400 transition-colors hover:border-white/20 hover:text-gray-200"
            >
              Select all
            </button>
            <button
              type="button"
              id="clear-all-categories-btn"
              class="flex-1 rounded-md border border-white/10 px-2 py-1.5 text-xs font-medium text-gray-400 transition-colors hover:border-white/20 hover:text-gray-200"
            >
              Clear all
            </button>
          </div>
        </div>

        <!-- Hide-completed toggle -->
        <label
          class="flex cursor-pointer items-center justify-between rounded-xl border border-white/10 bg-slate px-5 py-4"
          for="hide-completed-toggle"
        >
          <span class="text-sm text-gray-300">Hide found items</span>
          <input
            type="checkbox"
            id="hide-completed-toggle"
            class="h-4 w-4 cursor-pointer rounded border-white/20 bg-midnight text-neon accent-neon focus-visible:ring-2 focus-visible:ring-neon/40"
          />
        </label>

      </aside>

      <!-- ══════════════════════════════════════════════════════════════ -->
      <!-- RIGHT PANEL — collectible cards list                            -->
      <!-- ══════════════════════════════════════════════════════════════ -->
      <div>
        <div
          id="tracker-card-list"
          class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3"
          role="list"
          aria-label="Collectible items"
        >
          <!-- Cards are rendered client-side by tracker.ts so they can react
               to filter/checkbox state without a full page reload. Server-
               rendered fallback cards below ensure content is visible even
               if JavaScript fails to load. -->
          {
            items.map((item) => (
              <article
                class="tracker-card group relative flex flex-col gap-3 rounded-xl border border-white/10 bg-slate p-5 transition-colors"
                data-item-id={item.id}
                data-item-category={item.category}
                role="listitem"
              >
                <div class="flex items-start justify-between gap-3">
                  <span class="rounded border border-neon-border bg-neon-glow px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.1em] text-neon">
                    {categories[item.category as keyof typeof categories]}
                  </span>
                  <span class="font-mono text-[10px] text-gray-600">{item.id}</span>
                </div>

                <p class="text-sm leading-relaxed text-gray-300">{item.location}</p>

                <div class="flex flex-wrap gap-x-4 gap-y-1 rounded-md bg-midnight/60 px-3 py-2 font-mono text-[11px] text-gray-500">
                  <span>X: <span class="text-gray-300">{item.coordinates.x.toFixed(2)}</span></span>
                  <span>Y: <span class="text-gray-300">{item.coordinates.y.toFixed(2)}</span></span>
                  <span>Z: <span class="text-gray-300">{item.coordinates.z.toFixed(2)}</span></span>
                </div>

                <div class="mt-1 flex items-center gap-2">
                  {item.video_url ? (
                    <a
                      href={item.video_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex flex-1 items-center justify-center gap-1.5 rounded-md border border-white/10 px-3 py-2 text-xs font-medium text-gray-300 transition-colors hover:border-neon-border hover:text-neon"
                    >
                      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M5 3.5v9l7-4.5-7-4.5Z" fill="currentColor" />
                      </svg>
                      View Video
                    </a>
                  ) : (
                    <span class="inline-flex flex-1 items-center justify-center gap-1.5 rounded-md border border-white/5 px-3 py-2 text-xs font-medium text-gray-600">
                      No video yet
                    </span>
                  )}

                  <button
                    type="button"
                    class="collect-toggle-btn inline-flex items-center gap-1.5 rounded-md border border-white/10 px-3 py-2 text-xs font-semibold text-gray-300 transition-colors hover:border-neon-border hover:text-neon"
                    data-toggle-id={item.id}
                    aria-pressed="false"
                  >
                    <svg class="check-icon" width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M3 8.5 6.5 12 13 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span class="collect-toggle-label">Mark found</span>
                  </button>
                </div>
              </article>
            ))
          }
        </div>

        <!-- Empty state — shown when filters exclude every item -->
        <div id="empty-state" class="hidden flex-col items-center justify-center rounded-xl border border-dashed border-white/10 px-6 py-16 text-center">
          <p class="font-display text-xl font-bold text-gray-300">No collectibles match your filters</p>
          <p class="mt-1 text-sm text-gray-500">Try selecting more categories or turning off "Hide found items."</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Inline JSON payload — the build-time catalogue, handed to the client
       island below. Using a script tag with type="application/json" avoids
       re-fetching the file over the network; it's already in the page. -->
  <script type="application/json" id="collectibles-payload" set:html={JSON.stringify(collectiblesData)} />

  <script>
    // ===========================================================================
    // Tracker island — vanilla TypeScript, no framework runtime.
    // Reads the inline JSON payload, talks to storage.ts for all persistence,
    // and re-renders only the parts of the DOM that depend on state.
    // ===========================================================================
    import {
      getInitialState,
      toggleCollectible,
      updatePreferences,
      resetProgress,
      computeStats,
      type CollectibleItem,
    } from "../utils/storage";

    interface CollectiblesPayload {
      readonly categories: Record<string, string>;
      readonly items: CollectibleItem[];
    }

    // ── Read the build-time catalogue from the inline JSON payload ─────────
    const payloadEl = document.getElementById("collectibles-payload");
    if (!payloadEl || !payloadEl.textContent) {
      throw new Error("[tracker] Missing collectibles payload — cannot initialise tracker.");
    }
    const { categories, items }: CollectiblesPayload = JSON.parse(payloadEl.textContent);

    // ── Local (non-persisted) multi-category filter state ──────────────────
    // storage.ts's Preferences.categoryFilter is a single nullable string,
    // which doesn't support the multi-select checkbox UI this page needs.
    // Rather than change that file's schema (out of scope here), category
    // selection is tracked locally in this island and not persisted across
    // visits — only hideCompleted (already in Preferences) is persisted.
    const activeCategories = new Set<string>(Object.keys(categories));

    // ── DOM references ──────────────────────────────────────────────────────
    const cardListEl = document.getElementById("tracker-card-list");
    const emptyStateEl = document.getElementById("empty-state");
    const progressPercentEl = document.getElementById("progress-percent");
    const progressCompletedEl = document.getElementById("progress-completed");
    const progressTotalEl = document.getElementById("progress-total");
    const progressBarFillEl = document.getElementById("progress-bar-fill");
    const progressBarTrackEl = document.getElementById("progress-bar-track");
    const hideCompletedToggleEl = document.getElementById(
      "hide-completed-toggle"
    ) as HTMLInputElement | null;
    const resetBtnEl = document.getElementById("reset-progress-btn");
    const selectAllBtnEl = document.getElementById("select-all-categories-btn");
    const clearAllBtnEl = document.getElementById("clear-all-categories-btn");
    const categoryCheckboxes = Array.from(
      document.querySelectorAll<HTMLInputElement>(".category-filter-checkbox")
    );

    if (
      !cardListEl ||
      !emptyStateEl ||
      !progressPercentEl ||
      !progressCompletedEl ||
      !progressTotalEl ||
      !progressBarFillEl ||
      !progressBarTrackEl ||
      !hideCompletedToggleEl ||
      !resetBtnEl ||
      !selectAllBtnEl ||
      !clearAllBtnEl
    ) {
      throw new Error("[tracker] One or more required DOM elements were not found.");
    }

    // ── Render functions ────────────────────────────────────────────────────

    /**
     * Updates the progress card's percentage, fraction, and bar fill width
     * from a freshly computed CompletionStats object.
     */
    function renderProgressCard(): void {
      const state = getInitialState();
      const stats = computeStats(items, state.progress.completedIds);

      progressPercentEl!.textContent = `${stats.percent}%`;
      progressCompletedEl!.textContent = String(stats.completed);
      progressTotalEl!.textContent = String(stats.total);
      progressBarFillEl!.style.width = `${stats.percent}%`;
      progressBarTrackEl!.setAttribute("aria-valuenow", stats.percent);
    }

    /**
     * Updates the small count badge next to each category checkbox to show
     * how many items in that category are currently marked as found.
     */
    function renderCategoryCounts(): void {
      const state = getInitialState();
      const completedSet = new Set(state.progress.completedIds);

      for (const categoryKey of Object.keys(categories)) {
        const countEl = document.querySelector<HTMLElement>(
          `[data-category-count="${categoryKey}"]`
        );
        if (!countEl) continue;

        const totalInCategory = items.filter((i) => i.category === categoryKey).length;
        const completedInCategory = items.filter(
          (i) => i.category === categoryKey && completedSet.has(i.id)
        ).length;

        countEl.textContent = `${completedInCategory}/${totalInCategory}`;
      }
    }

    /**
     * Applies the current category-filter and hide-completed preference to
     * every card in the DOM, toggling visibility rather than removing and
     * re-creating nodes — cheaper, and preserves each card's toggle button
     * state without a full re-render.
     */
    function applyFilters(): void {
      const state = getInitialState();
      const completedSet = new Set(state.progress.completedIds);
      const hideCompleted = state.preferences.hideCompleted;

      let visibleCount = 0;

      const cards = cardListEl!.querySelectorAll<HTMLElement>(".tracker-card");
      cards.forEach((card) => {
        const itemId = card.dataset.itemId ?? "";
        const itemCategory = card.dataset.itemCategory ?? "";
        const isCompleted = completedSet.has(itemId);

        const matchesCategory = activeCategories.has(itemCategory);
        const matchesCompletionFilter = hideCompleted ? !isCompleted : true;
        const isVisible = matchesCategory && matchesCompletionFilter;

        card.classList.toggle("hidden", !isVisible);
        if (isVisible) visibleCount += 1;
      });

      emptyStateEl!.classList.toggle("hidden", visibleCount > 0);
      emptyStateEl!.classList.toggle("flex", visibleCount === 0);
    }

    /**
     * Updates a single card's visual "found" state — check icon, label
     * text, button styling, and aria-pressed — without touching any other
     * card. Called immediately on toggle for instant feedback, before the
     * heavier renderProgressCard/renderCategoryCounts/applyFilters batch.
     */
    function renderCardCollectedState(itemId: string, isCollected: boolean): void {
      const card = cardListEl!.querySelector<HTMLElement>(
        `.tracker-card[data-item-id="${itemId}"]`
      );
      if (!card) return;

      const btn = card.querySelector<HTMLButtonElement>(".collect-toggle-btn");
      const label = card.querySelector<HTMLElement>(".collect-toggle-label");
      if (!btn || !label) return;

      btn.setAttribute("aria-pressed", String(isCollected));
      label.textContent = isCollected ? "Found" : "Mark found";

      card.classList.toggle("border-neon-border", isCollected);
      card.classList.toggle("bg-neon-glow/40", isCollected);
      btn.classList.toggle("border-neon", isCollected);
      btn.classList.toggle("bg-neon", isCollected);
      btn.classList.toggle("text-midnight", isCollected);
      btn.classList.toggle("text-gray-300", !isCollected);
    }

    /**
     * Full re-render: applies the current persisted state to every card's
     * collected styling. Used once on initial load to sync server-rendered
     * markup with whatever progress is already saved in localStorage.
     */
    function hydrateAllCardStates(): void {
      const state = getInitialState();
      const completedSet = new Set(state.progress.completedIds);

      for (const item of items) {
        renderCardCollectedState(item.id, completedSet.has(item.id));
      }
    }

    /**
     * Runs the full set of state-dependent renders in one batch. Called
     * after any mutation (toggle, filter change, reset) so every part of
     * the UI — progress card, category counts, card visibility — reflects
     * the new state together, avoiding visible inconsistency between panels.
     */
    function renderAll(): void {
      hydrateAllCardStates();
      renderProgressCard();
      renderCategoryCounts();
      applyFilters();
    }

    // ── Event wiring ─────────────────────────────────────────────────────

    // Toggle a single collectible's collected state. Event delegation on the
    // card list container means this works for every card without binding
    // a listener per-button, and continues to work if cards are ever
    // re-rendered dynamically in the future.
    cardListEl.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      const toggleBtn = target.closest<HTMLButtonElement>(".collect-toggle-btn");
      if (!toggleBtn) return;

      const itemId = toggleBtn.dataset.toggleId;
      if (!itemId) return;

      const nextState = toggleCollectible(itemId);
      const isNowCollected = nextState.progress.completedIds.includes(itemId);

      // Instant feedback on the single affected card first...
      renderCardCollectedState(itemId, isNowCollected);
      // ...then the batched re-render for progress, counts, and filters.
      renderProgressCard();
      renderCategoryCounts();
      applyFilters();
    });

    // Category checkboxes — multi-select, local state only.
    categoryCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", () => {
        const categoryKey = checkbox.dataset.category;
        if (!categoryKey) return;

        if (checkbox.checked) {
          activeCategories.add(categoryKey);
        } else {
          activeCategories.delete(categoryKey);
        }

        applyFilters();
      });
    });

    // Select all / clear all category shortcuts.
    selectAllBtnEl.addEventListener("click", () => {
      activeCategories.clear();
      for (const key of Object.keys(categories)) activeCategories.add(key);
      categoryCheckboxes.forEach((cb) => (cb.checked = true));
      applyFilters();
    });

    clearAllBtnEl.addEventListener("click", () => {
      activeCategories.clear();
      categoryCheckboxes.forEach((cb) => (cb.checked = false));
      applyFilters();
    });

    // Hide-completed toggle — persisted via storage.ts's Preferences.
    const initialPrefsState = getInitialState();
    hideCompletedToggleEl.checked = initialPrefsState.preferences.hideCompleted;

    hideCompletedToggleEl.addEventListener("change", () => {
      updatePreferences({ hideCompleted: hideCompletedToggleEl!.checked });
      applyFilters();
    });

    // Reset progress — confirms before wiping, since this is destructive
    // and there is no undo (no backend, no history).
    resetBtnEl.addEventListener("click", () => {
      const confirmed = window.confirm(
        "Reset all tracked progress? This cannot be undone."
      );
      if (!confirmed) return;

      resetProgress();
      renderAll();
    });

    // ── Cross-tab synchronisation ───────────────────────────────────────
    // If the visitor has this page open in two tabs and toggles a
    // collectible in one, reflect it in the other via the native
    // `storage` event, which only fires in tabs that did NOT make the
    // write themselves.
    window.addEventListener("storage", (event) => {
      if (event.key !== "gta6_tracker_progress") return;
      renderAll();
    });

    // ── Initial render ──────────────────────────────────────────────────
    renderAll();
  </script>
</Layout>
