---
const navLinks = [
  { href: "/news", label: "News" },
  { href: "/tracker", label: "Tracker" },
  { href: "/videos", label: "Videos" },
  { href: "/deals", label: "Deals" },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" role="banner">
  <div class="header-inner">
    <!-- Wordmark -->
    <a href="/" class="wordmark" aria-label="Leonida Hub — home">
      <span class="wordmark-l">L</span><span class="wordmark-rest">eonida</span>
      <span class="wordmark-sep"></span>
      <span class="wordmark-hub">HUB</span>
    </a>

    <!-- Nav -->
    <nav aria-label="Primary navigation">
      <ul class="nav-list" role="list">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class={`nav-link ${currentPath.startsWith(href) ? "nav-link--active" : ""}`}
                aria-current={currentPath.startsWith(href) ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Launch chip -->
    <div class="launch-chip" aria-label="GTA VI launches November 19 2026">
      <span class="launch-dot" aria-hidden="true"></span>
      <span class="launch-label">NOV 19</span>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    border-bottom: 1px solid var(--border-subtle);
    background: rgba(1, 3, 16, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  /* Wordmark */
  .wordmark {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 800;
    font-size: 20px;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .wordmark-l {
    color: var(--neon);
  }

  .wordmark-rest {
    color: var(--text-primary);
  }

  .wordmark-sep {
    display: inline-block;
    width: 1px;
    height: 14px;
    background: var(--border-neon);
    margin: 0 8px;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }

  .wordmark-hub {
    color: var(--neon);
    font-size: 13px;
    letter-spacing: 0.18em;
    font-weight: 700;
  }

  /* Nav */
  .nav-list {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    flex: 1;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
    transition:
      color 0.15s,
      background 0.15s;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-link--active {
    color: var(--neon);
  }

  .nav-link--active:hover {
    color: var(--neon-bright);
    background: var(--neon-glow);
  }

  /* Launch chip */
  .launch-chip {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border: 1px solid var(--border-neon);
    border-radius: 100px;
    background: var(--neon-glow);
    flex-shrink: 0;
  }

  .launch-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--neon);
    animation: pulse-neon 3s ease-in-out infinite;
  }

  .launch-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    font-weight: 500;
    color: var(--neon);
    letter-spacing: 0.1em;
  }

  @keyframes pulse-neon {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  @media (max-width: 640px) {
    .nav-list {
      gap: 0;
    }
    .nav-link {
      padding: 6px 8px;
      font-size: 12px;
    }
    .launch-chip {
      display: none;
    }
  }
</style>
